# Discord bot   
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=


REDIS_PASSWORD=
REDIS_URL=

POSTGRES_PASSWORD=
DATABASE_URL=

PGADMIN_PASSWORD=

GRAFANA_PASSWORD=
# Optional
OWNER_IDS=
KEYV_URL=sqlite://database.sqlite

YTDLP_MAX_CONCURRENT=8
YTDLP_QUEUE_TIMEOUT_MS=30000

# ── Music: YouTube bot-detection bypass ─────────────────────────────────────
# Without these, heavily bot-guarded videos may fail with "Sign in to confirm"
# or stream silently at 0.1% progress then disconnect.
# yt-dlp version must be kept up-to-date — run: yt-dlp -U (or replace bin/yt-dlp.exe)
#
# Option A — Cookie file (recommended, works headlessly on servers):
#   1. Install "Get cookies.txt LOCALLY" browser extension while logged into YouTube
#   2. Export cookies to a file (e.g. cookies.txt in project root)
#   3. Uncomment and set the path below:
# YTDLP_COOKIES_FILE=./cookies.txt
#
# Option B — Browser cookies (only works if browser is on the same machine):
# YTDLP_COOKIES_BROWSER=chrome
#
# Option C — PO Token (pairs with cookie auth, further reduces bot-detection):
#   See: https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
# YTDLP_PO_TOKEN=
# YTDLP_PO_TOKEN_VISITOR_DATA=

SHARD_COUNT=1
SHARD_DELAY_MS=5500

ACTIVITY_ROTATE_MS=30000
ACTIVITY_TEXT=!help or /help to see commands
STREAM_URL=https://twitch.tv/discord

# Developer-only /dev tools
# /dev is allowed for:
#  1) Members of the bot's Discord Developer Portal "Team" (recommended), and/or
#  2) User IDs you invite below (testers / temporary access)
# If the app is not in a Team and BOT_DEV_USER_IDS is empty, /dev will be blocked.
BOT_DEV_USER_IDS=
# Optional: only allow /dev tools in specific guild(s)
BOT_DEV_GUILD_IDS=
# Optional: how often to refresh Team membership from Discord (minutes)
BOT_DEV_CACHE_MINUTES=360

# Legal links (optional, used in /help and !help)
PRIVACY_POLICY_URL=
TERMS_URL=
