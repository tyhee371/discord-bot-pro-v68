# Discord bot
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE
CLIENT_ID=YOUR_APPLICATION_CLIENT_ID
GUILD_ID=YOUR_TEST_GUILD_ID   # required for npm run deploy:guild
REDIS_URL=YOUR_REDIS_URL_HERE

# Optional
OWNER_IDS=123,456
KEYV_URL=sqlite://database.sqlite

# Developer-only /dev tools
# /dev is allowed for:
#  1) Members of the bot's Discord Developer Portal "Team" (recommended), and/or
#  2) User IDs you invite below (testers / temporary access)
# If the app is not in a Team and BOT_DEV_USER_IDS is empty, /dev will be blocked.
BOT_DEV_USER_IDS=123456789012345678,234567890123456789
# Optional: only allow /dev tools in specific guild(s)
BOT_DEV_GUILD_IDS=123456789012345678
# Optional: how often to refresh Team membership from Discord (minutes)
BOT_DEV_CACHE_MINUTES=360

# Legal links (optional, used in /help and !help)
PRIVACY_POLICY_URL=
TERMS_URL=
