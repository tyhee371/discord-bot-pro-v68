>>>>>>> 01c881a (Update README, DEPLOYMENT, requirements, and .env.example)

# Discord application settings
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
CLIENT_ID=YOUR_CLIENT_ID_HERE
GUILD_ID=YOUR_TEST_GUILD_ID_HERE

# Redis configuration
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_URL=redis://:YOUR_REDIS_PASSWORD_HERE@redis:6379

# PostgreSQL configuration
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
DATABASE_URL=postgresql://bot_user:YOUR_POSTGRES_PASSWORD_HERE@postgres:5432/bot_db

# Optional admin tools
PGADMIN_PASSWORD=YOUR_PGADMIN_PASSWORD_HERE
GRAFANA_PASSWORD=YOUR_GRAFANA_PASSWORD_HERE

# Optional bot settings
OWNER_IDS=YOUR_USER_ID_HERE
KEYV_URL=sqlite://database.sqlite

# YouTube playback settings
YTDLP_MAX_CONCURRENT=8
YTDLP_QUEUE_TIMEOUT_MS=30000
YTDLP_COOKIES_FILE=./cookies.txt

# Spotify integration (optional)
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET_HERE

# Sharding and presence
SHARD_COUNT=1
SHARD_DELAY_MS=5500
ACTIVITY_ROTATE_MS=30000
ACTIVITY_TEXT=!help or /help to see commands
STREAM_URL=https://twitch.tv/discord

# Developer-only /dev tools
# /dev is allowed for members of the bot's Developer Portal team
# or user IDs listed below.
BOT_DEV_USER_IDS=YOUR_USER_ID_HERE
BOT_DEV_GUILD_IDS=YOUR_GUILD_ID_HERE
BOT_DEV_CACHE_MINUTES=360

# Legal links (optional; shown in /help)
PRIVACY_POLICY_URL=
TERMS_URL=
