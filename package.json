{
  "name": "discord-bot-pro-v68",
  "version": "68.0.0",
  "description": "Discord bot with moderation, tickets, temp voice channel manager, greet/leave - discord.js v14.25.1",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --dns-result-order=ipv4first --env-file=.env src/index.js",
    "start:shard": "node --dns-result-order=ipv4first --env-file=.env src/shard.js",
    "deploy:guild": "node --dns-result-order=ipv4first --env-file=.env src/deploy-commands.js --guild",
    "deploy:clear-guild": "node --dns-result-order=ipv4first --env-file=.env src/deploy-commands.js --clear-guild",
    "deploy:global": "node --dns-result-order=ipv4first --env-file=.env src/deploy-commands.js --global",
    "doctor": "node --dns-result-order=ipv4first src/doctor.js",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "migrate:dry-run": "node scripts/migrate.js --dry-run",
    "lint": "eslint .",
    "format": "prettier -w .",
    "smoke": "node scripts/smoke.js",
    "smoke-test": "node scripts/smoke-test.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22.12.0 <25.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.0",
    "@distube/ytdl-core": "4.16.12",
    "@keyv/sqlite": "4.0.2",
    "@snazzah/davey": "0.1.9",
    "discord.js": "14.25.1",
    "ffmpeg-static": "5.2.0",
    "keyv": "5.5.0",
    "libsodium-wrappers": "0.7.15",
    "opusscript": "0.1.1",
    "pg": "^8.11.3",
    "pino": "9.7.0",
    "pino-pretty": "11.3.0",
    "play-dl": "1.9.7",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "eslint": "9.18.0",
    "prettier": "3.4.2"
  },
  "optionalDependencies": {
    "@discordjs/opus": "^0.10.0"
  }
}